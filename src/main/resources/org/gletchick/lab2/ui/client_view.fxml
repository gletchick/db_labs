<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="10" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.gletchick.lab2.ui.ClientController">
    <padding>
        <Insets bottom="15" left="15" right="15" top="15" />
    </padding>
    <TableView fx:id="clientTable" prefHeight="200" VBox.vgrow="ALWAYS">
        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
        <columns>
            <TableColumn fx:id="colSurname" text="Фамилия" />
            <TableColumn fx:id="colName" text="Имя" />
            <TableColumn fx:id="colPatronymic" text="Отчество" />
            <TableColumn fx:id="colPhone" text="Телефон" />
        </columns>
    </TableView>

    <GridPane alignment="CENTER" hgap="10" vgap="10">
        <TextField fx:id="txtSurname" promptText="Фамилия" GridPane.columnIndex="0" GridPane.rowIndex="0" />
        <TextField fx:id="txtName" promptText="Имя" GridPane.columnIndex="1" GridPane.rowIndex="0" />
        <TextField fx:id="txtPatronymic" promptText="Отчество" GridPane.columnIndex="0" GridPane.rowIndex="1" />
        <TextField fx:id="txtPhone" promptText="Телефон" GridPane.columnIndex="1" GridPane.rowIndex="1" />
      <columnConstraints>
         <ColumnConstraints />
         <ColumnConstraints />
      </columnConstraints>
      <rowConstraints>
         <RowConstraints />
         <RowConstraints />
      </rowConstraints>
    </GridPane>

    <HBox alignment="CENTER" spacing="10">

        <Button onAction="#handleAddLocal" text="Добавить локально" />
        <Button onAction="#handleSaveToDb" text="Сохранить в БД" />
        <Button onAction="#handleRefresh" text="Прочитать из БД" />
    </HBox>
</VBox>
