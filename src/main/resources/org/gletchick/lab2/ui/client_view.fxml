<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="10" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.gletchick.lab2.ui.ClientController">
    <padding>
        <Insets bottom="15" left="15" right="15" top="15" />
    </padding>

    <HBox alignment="CENTER" spacing="15" style="-fx-padding: 10; -fx-border-color: lightgray; -fx-border-radius: 5;">
        <Label text="Фильтры:" style="-fx-font-weight: bold;"/>
        <ComboBox fx:id="comboFilterSurname" promptText="Выберите фамилию" prefWidth="150"/>
        <ComboBox fx:id="comboFilterPhone" promptText="Выберите телефон" prefWidth="150"/>
        <Button text="Сбросить фильтры" onAction="#handleClearFilters"/>
    </HBox>

    <SplitPane dividerPositions="0.5" VBox.vgrow="ALWAYS" prefHeight="350">
        <items>
            <VBox spacing="5">
                <Label style="-fx-font-weight: bold;" text="Таблица 1 (Сортировка: Имя)" />
                <TableView fx:id="clientTable1" VBox.vgrow="ALWAYS">
                    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                    <columns>
                        <TableColumn fx:id="colComputed" text="ФИО (Кратко) *" style="-fx-background-color: #e8f5e9;"/>
                        <TableColumn fx:id="col1Surname" text="Фамилия" />
                        <TableColumn fx:id="col1Name" text="Имя" />
                        <TableColumn fx:id="col1Phone" text="Телефон" />
                    </columns>
                </TableView>
            </VBox>

            <VBox spacing="5">
                <Label style="-fx-font-weight: bold;" text="Таблица 2 (Сортировка: Телефон)" />
                <TableView fx:id="clientTable2" VBox.vgrow="ALWAYS">
                    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                    <columns>
                        <TableColumn fx:id="col2Surname" text="Фамилия" />
                        <TableColumn fx:id="col2Name" text="Имя" />
                        <TableColumn fx:id="col2Phone" text="Телефон" />
                    </columns>
                </TableView>
            </VBox>
        </items>
    </SplitPane>

    <Button onAction="#handleRefresh" prefWidth="250" text="Загрузить данные из БД" style="-fx-font-weight: bold; -fx-base: #c8e6c9;" />
</VBox>