<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="700.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.gletchick.lab2.controller.MainController">
    <left>
        <VBox spacing="10.0" style="-fx-background-color: #f4f4f4; -fx-border-color: #ccc; -fx-border-width: 0 1 0 0;">
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
            <Label text="Таблицы">
                <Font name="System Bold" size="14.0" />
            </Label>
            <Button maxWidth="1.7976931348623157E308" onAction="#showClients" text="Клиенты" />
            <Button maxWidth="1.7976931348623157E308" onAction="#showTickets" text="Билеты" />
            <Button maxWidth="1.7976931348623157E308" onAction="#showSpectacles" text="Спектакли" />
            <Button maxWidth="1.7976931348623157E308" onAction="#showHalls" text="Залы" />
            <Button maxWidth="1.7976931348623157E308" onAction="#showSeats" text="Места" />
            <Button maxWidth="1.7976931348623157E308" onAction="#showSessions" text="Сеансы" />
        </VBox>
    </left>
    <center>
        <StackPane fx:id="contentArea">
            <Label text="Выберите таблицу в меню слева" textFill="#888888" />
        </StackPane>
    </center>
</BorderPane>